# Database
DATABASE_URL=postgres://timesheet:timesheet@localhost:5432/timesheet

# Auth
JWT_SECRET=change-me-use-openssl-rand-base64-64
JWT_EXPIRY_HOURS=24

# Seed (only used by task seed, not at runtime)
ADMIN_USER=yannick
ADMIN_PASS=change-me

# File uploads
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Puppeteer
PUPPETEER_NO_SANDBOX=false
