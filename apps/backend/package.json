{
  "name": "@timesheet/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests --coverage --reporter=default --reporter=junit",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@timesheet/shared": "workspace:*",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.2.0",
    "postgres": "^3.4.8",
    "puppeteer": "^24.38.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
