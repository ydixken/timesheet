{
  "name": "@timesheet/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests --coverage --reporter=default --reporter=junit",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "@timesheet/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "jose": "^6.0.11",
    "postgres": "^3.4.5",
    "puppeteer": "^24.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
